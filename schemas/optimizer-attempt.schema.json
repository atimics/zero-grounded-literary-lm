{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atimics.github.io/zero-grounded-literary-lm/schemas/optimizer-attempt.schema.json",
  "title": "ZERO optimizer attempt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "attempt", "proposed_committed_update", "committed_update",
    "phase", "mode", "source_mask", "source_ids", "replay_range", "learning_rate",
    "guard_budget", "functional_probe", "probe_before", "probe_after",
    "relative_probe_change", "faculty_replay_gradient_cosine",
    "gradient_norm", "displacement_norm", "predicted_replay_drift",
    "fisher_weighted_drift", "decision", "reason", "rollback_digest",
    "groups"
  ],
  "properties": {
    "schema": { "const": "zero.optimizer_attempt.v1" },
    "attempt": { "type": "integer", "minimum": 1 },
    "proposed_committed_update": { "type": "integer", "minimum": 1 },
    "committed_update": { "type": "integer", "minimum": 0 },
    "phase": { "enum": ["observer", "acquisition", "consolidation", "recovery", "smoke"] },
    "mode": { "enum": ["observer", "guard"] },
    "source_mask": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0, "maximum": 63 }
    },
    "replay_range": { "type": "integer", "minimum": 0 },
    "learning_rate": { "type": "number", "minimum": 0 },
    "guard_budget": { "type": "number", "minimum": 0 },
    "functional_probe": { "type": "boolean" },
    "probe_before": { "type": ["number", "null"] },
    "probe_after": { "type": ["number", "null"] },
    "relative_probe_change": { "type": ["number", "null"] },
    "faculty_replay_gradient_cosine": { "type": ["number", "null"], "minimum": -1, "maximum": 1 },
    "gradient_norm": { "type": "number", "minimum": 0 },
    "displacement_norm": { "type": "number", "minimum": 0 },
    "predicted_replay_drift": { "type": "number" },
    "fisher_weighted_drift": { "type": "number", "minimum": 0 },
    "decision": { "enum": ["accept", "reject"] },
    "reason": { "type": "string", "minLength": 1 },
    "rollback_digest": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "replay_drift", "displacement_norm", "fisher_weighted_drift"],
        "properties": {
          "id": { "type": "string", "pattern": "^(token_embedding|position_embedding|final_norm|layer\\.[0-9]+\\.(norm1|wq|wk|wv|wo|norm2|w1|w2))$" },
          "replay_drift": { "type": "number" },
          "displacement_norm": { "type": "number", "minimum": 0 },
          "fisher_weighted_drift": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
